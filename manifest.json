{
  "manifest_version": 3,
  "name": "YouTube Transcript Extractor",
  "version": "1.2",
  "description": "Extracts and summarizes transcripts from YouTube videos using Gemini.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.mistral.ai/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/watch?v=*"],
      "js": ["scripts/constants.js", "scripts/transcript-engine.js", "scripts/ui-builder.js", "scripts/dom-observer.js", "scripts/content-main.js"],
      "css": ["styles/content.css"]
    }
  ]
}
