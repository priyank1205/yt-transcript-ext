{
  "manifest_version": 3,
  "name": "YouTube Transcript Extractor",
  "version": "1.1",
  "description": "Extracts and summarizes transcripts from YouTube videos using Gemini.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/watch?v=*"],
      "js": ["scripts/content.js"]
    }
  ]
}
